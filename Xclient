    stLastPos=nil
end

local function startStrafe()
    if stOn then return end
    stOn=true
    stLastPos=Root and Root.Position or Vector3.zero
    stTraveled=0
    stConn=RunSvc.Heartbeat:Connect(function(dt)
        if not stOn then return end
        local ch=LP.Character
