-- ── Long Jump ──────────────────────────────────────────────────────
local function stopLJ()
    if not ljOn then return end
    ljOn=false
    if ljConn then ljConn:Disconnect() ljConn=nil end
    if ljStConn then ljStConn:Disconnect() ljStConn=nil end
    local hm=LP.Character and LP.Character:FindFirstChild("Humanoid")
    if hm then hm.JumpPower=ljOrig end
end

local function startLJ()
    if ljOn then return end
    ljOn=true
    local hm=LP.Character and LP.Character:FindFirstChild("Humanoid")
    if not hm then 
        ljOn=false
        return 
    end
    ljOrig=hm.JumpPower
    hm.JumpPower=ljOrig*ljMultiplier
    ljConn=UIS.JumpRequest:Connect(function()
        local ch=LP.Character
        local h2=ch and ch:FindFirstChild("Humanoid")
        local rt=ch and ch:FindFirstChild("HumanoidRootPart")
        if not h2 or not rt then return end
        local bv=mkBV(rt,"xcLJBV")
        bv.Velocity=Vector3.new(rt.AssemblyLinearVelocity.X,ljOrig*2.7,rt.AssemblyLinearVelocity.Z)
        h2:ChangeState(Enum.HumanoidStateType.Jumping)
        task.delay(.35,function() 
            if bv and bv.Parent then bv:Destroy() end 
        end)
    end)
    ljStConn=RunSvc.Heartbeat:Connect(function()
        local ch=LP.Character
        local h2=ch and ch:FindFirstChild("Humanoid")
        if h2 and ljOn then 
            h2.JumpPower=ljOrig*ljMultiplier 
        end
    end)
end

