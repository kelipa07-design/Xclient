-- ── Noclip ────────────────────────────────────────────────────────
local function stopNC()
    if not ncOn then return end
    ncOn=false
    if ncConn then ncConn:Disconnect() ncConn=nil end
    local ch=LP.Character
    if not ch then return end
    for _,p in ipairs(ch:GetDescendants()) do
        if p:IsA("BasePart") then
            p.CanCollide=ncOrigCC[p] ~= nil and ncOrigCC[p] or true
        end
    end
    ncOrigCC={}
    stats.noclipTime=stats.noclipTime+(tick()-stats.startTime)
end

local function startNC()
    if ncOn then return end
    ncOn=true
    stats.startTime=tick()
    local ch=LP.Character
    if not ch then 
        ncOn=false
        return 
    end
    for _,p in ipairs(ch:GetDescendants()) do
        if p:IsA("BasePart") then 
            ncOrigCC[p]=p.CanCollide 
        end
    end
    ncConn=RunSvc.Stepped:Connect(function()
        local ch2=LP.Character
        if not ch2 then return end
        for _,p in ipairs(ch2:GetDescendants()) do
            if p:IsA("BasePart") then 
                p.CanCollide=false 
            end
        end
    end)
end

