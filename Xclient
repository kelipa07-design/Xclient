-- ══ ГОРЯЧИЕ КЛАВИШИ ═══════════════════════════════════════════════
local kbOn=true
local kbs={}

local function regKB(kc,fn) 
    kbs[kc]=fn 
end

UIS.InputBegan:Connect(function(inp,gp)
    if gp or not kbOn then return end
    local fn=kbs[inp.KeyCode]
    if fn then pcall(fn) end
end)

regKB(Enum.KeyCode.F,function()
    flyOn=not flyOn
    if flyOn then startFlight() else stopFlight() end
    notify("KB [F]",flyOn and "Flight ON" or "Flight OFF",TC)
end)

regKB(Enum.KeyCode.G,function()
    ncOn=not ncOn
    if ncOn then startNC() else stopNC() end
    notify("KB [G]",ncOn and "Noclip ON" or "Noclip OFF",TC)
end)

regKB(Enum.KeyCode.H,function()
    floatOn=not floatOn
    if floatOn then startFloat() else stopFloat() end
    notify("KB [H]",floatOn and "Float ON" or "Float OFF",TC)
end)

regKB(Enum.KeyCode.V,function()
    swOn=not swOn
    if swOn then startSW() else stopSW() end
    notify("KB [V]",swOn and "Speed Walk ON" or "Speed Walk OFF",TC)
end)

regKB(Enum.KeyCode.C,function()
    dodgeOn=not dodgeOn
    notify("KB [C]",dodgeOn and "Smart Dodge ON" or "Smart Dodge OFF",TC)
end)

