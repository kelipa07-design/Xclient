-- ── Magic Flight ──────────────────────────────────────────────────
local function stopFlight()
    if not flyOn then return end
    flyOn=false
    if flyConn then flyConn:Disconnect() flyConn=nil end
    if flyBV and flyBV.Parent then flyBV:Destroy() flyBV=nil end
    if flyBG and flyBG.Parent then flyBG:Destroy() flyBG=nil end
    pcall(function() Hum.PlatformStand=false end)
    stats.flightTime=stats.flightTime+(tick()-stats.startTime)
end

local function startFlight()
    if flyOn then return end
    flyOn=true
    stats.startTime=tick()
    flyBV=mkBV(Root,"xcFlyBV")
    local bg=Instance.new("BodyGyro")
    bg.Name="xcFlyBG"
    bg.MaxTorque=Vector3.new(0,1e5,0)
    bg.P=5000
    bg.CFrame=Root.CFrame
    bg.Parent=Root
    flyBG=bg
    Hum.PlatformStand=true
    wT=0
    wS=0
    dC=0
    dTgt=0
    dTmr=0
    flyConn=RunSvc.Heartbeat:Connect(function(dt)
        if not(Root and Root.Parent) or Hum.Health<=0 then 
            stopFlight()
            return 
        end
        local fwd,rgt=getCam()
        local md=Hum.MoveDirection
        local dir
        if md.Magnitude>.05 then
            local v=fwd*(-md.Z)+rgt*md.X
            dir=v.Magnitude>.001 and v.Unit or fwd
        else 
            dir=fwd 
        end
        local vy=0
        if UIS:IsKeyDown(Enum.KeyCode.Space) then 
            vy=20
        elseif UIS:IsKeyDown(Enum.KeyCode.LeftShift) or UIS:IsKeyDown(Enum.KeyCode.RightShift) then 
            vy=-20 
        end
        wT=wT+dt*1.6
        local sinW=math.sin(wT)*0.08
        dTmr=dTmr-dt
        if dTmr<=0 then 
            dTgt=(math.random()*2-1)*0.06
            dTmr=0.4+math.random()*0.7 
        end
        dC=dC+(dTgt-dC)*0.04
        wS=wS+dt*4.2
        local step=(math.abs(math.sin(wS))^3)*0.03*((math.floor(wS/math.pi)%2==0)and 1 or -1)
        local mult=(resolverOn and resActive) and 1.35 or 1
        flyBV.Velocity=Vector3.new(dir.X*flySpeed*mult,vy+(sinW+dC+step)*4,dir.Z*flySpeed*mult)
        flyBG.CFrame=CFrame.lookAt(Root.Position,Root.Position+dir)
    end)
end

