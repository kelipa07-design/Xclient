-- ── Smart Dodge ────────────────────────────────────────────────────
local function runDodge()
    local ch=LP.Character
    local hrp=ch and ch:FindFirstChild("HumanoidRootPart")
    local hm=ch and ch:FindFirstChild("Humanoid")
    if not hrp or not hm then return end
    if tick()-lastDodge<dCfg.CD then return end
    
    local bD=dCfg.R
    local bF=nil
    local bV=Vector3.zero
    
    for _,pl in ipairs(Players:GetPlayers()) do
        if pl==LP then continue end
        local c2=pl.Character
        if not c2 then continue end
        local r2=c2:FindFirstChild("HumanoidRootPart")
        if not r2 then continue end
        local v2=r2.AssemblyLinearVelocity
        local fut=r2.Position+v2*dCfg.PT
        local d=(fut-hrp.Position).Magnitude
        if d<bD then 
            bD=d
            bF=fut
            bV=v2 
        end
    end
    
    if not bF then return end
    local aw=(hrp.Position-bF)
    if aw.Magnitude<.01 then return end
    aw=aw.Unit
    local fd=(aw*.8+hm.MoveDirection*.3)
    if fd.Magnitude>.01 then 
        fd=fd.Unit 
    else 
        fd=aw 
    end
    local force=dCfg.BF+bV.Magnitude*dCfg.SM
    local bv=mkBV(hrp,"xcDgBV")
    bv.Velocity=Vector3.new(fd.X*force,hrp.AssemblyLinearVelocity.Y,fd.Z*force)
    task.delay(.22,function() 
        if bv and bv.Parent then bv:Destroy() end 
    end)
    lastDodge=tick()
    stats.dodgeCount=stats.dodgeCount+1
end

RunSvc.Heartbeat:Connect(function() 
    if dodgeOn then 
        pcall(runDodge) 
    end 
end)

-- ── Damage Fly ─────────────────────────────────────────────────────
local function updateDfHud(p)
    p=math.clamp(p,0,100)
    local col
    if p>60 then 
        col=Color3.fromRGB(math.floor(255*(1-(p-60)/40)),220,80)
    elseif p>30 then 
        col=Color3.fromRGB(255,math.floor(220*((p-30)/30)),30)
    else 
        col=Color3.fromRGB(255,math.floor(80*(p/30)),30) 
    end
    local vis=math.floor(#dfSegs*p/100+.5)
    for i,s in ipairs(dfSegs) do
        s.BackgroundColor3=col
        s.BackgroundTransparency=i<=vis and 0 or 0.88
    end
    if dfPctLbl then 
        dfPctLbl.Text=tostring(math.floor(p))
        dfPctLbl.TextColor3=col 
    end
    if dfHudFrame then 
        dfHudFrame.Visible=dfOn 
    end
end

local function stopDF()
    dfActive=false
    if dfConn then dfConn:Disconnect() dfConn=nil end
    if dfBVO and dfBVO.Parent then dfBVO:Destroy() dfBVO=nil end
    if not flyOn then 
        pcall(function() Hum.PlatformStand=false end) 
    end
end

local function startDF()
    if dfActive or dfCharge<=0 then return end
    dfActive=true
    stats.damageFlys=stats.damageFlys+1
    dfBVO=mkBV(Root,"xcDfBV")
    Hum.PlatformStand=true
    dfConn=RunSvc.Heartbeat:Connect(function(dt)
        if not(Root and Root.Parent) or Hum.Health<=0 then 
            stopDF()
            return 
        end
        if dfActive then
            dfCharge=math.max(0,dfCharge-10*dt)
            updateDfHud(dfCharge)
            if dfCharge<=0 then
                notify("Damage Fly","Заряд кончился! Постой",Color3.fromRGB(255,80,60))
                dfActive=false
                stopDF()
                return
            end
            local fwd,rgt=getCam()
            local md=Hum.MoveDirection
            local dir=fwd
            if md.Magnitude>.05 then 
                local v=fwd*(-md.Z)+rgt*md.X
                if v.Magnitude>.001 then dir=v.Unit end 
            end
            local vy=0
            if UIS:IsKeyDown(Enum.KeyCode.Space) then 
                vy=16
            elseif UIS:IsKeyDown(Enum.KeyCode.LeftShift) or UIS:IsKeyDown(Enum.KeyCode.RightShift) then 
                vy=-16 
            end
            dfBVO.Velocity=Vector3.new(dir.X*18,vy,dir.Z*18)
        else
            Hum.PlatformStand=false
            if dfBVO then dfBVO.Velocity=Vector3.zero end
            if Hum.MoveDirection.Magnitude<0.05 then
                dfCharge=math.min(100,dfCharge+5*dt)
                updateDfHud(dfCharge)
                if dfCharge>=100 then
                    notify("Damage Fly","Заряд восстановлен!",Color3.fromRGB(80,220,100))
                    if dfConn then dfConn:Disconnect() dfConn=nil end
                end
            end
        end
    end)
end

local function connectDmg()
    if dfDmgConn then dfDmgConn:Disconnect() end
    local prev=Hum.Health
    dfDmgConn=Hum.HealthChanged:Connect(function(hp)
        if not dfOn then return end
        if hp<prev then startDF() end
        prev=hp
    end)
end

local function setDF(v)
    dfOn=v
    if v then 
        connectDmg()
    else 
        stopDF()
        if dfDmgConn then dfDmgConn:Disconnect() dfDmgConn=nil end 
    end
end

-- ── Resolver ───────────────────────────────────────────────────────
RunSvc.Heartbeat:Connect(function()
    if not resolverOn then 
        resActive=false
        return 
    end
    local mp=Root and Root.Position or Vector3.zero
    local cl=math.huge
    for _,pl in ipairs(Players:GetPlayers()) do
        if pl==LP then continue end
        local ch=pl.Character
        if not ch then continue end
        local r=ch:FindFirstChild("HumanoidRootPart")
        if not r then continue end
        local d=(r.Position-mp).Magnitude
        if d<cl then cl=d end
        if d<=13 then 
            resActive=true
            return 
        end
    end
    if cl>10 then resActive=false end
end)

